@inproceedings{lieberum-etal-2024-gemma,
    title = "Gemma Scope: Open Sparse Autoencoders Everywhere All At Once on Gemma 2",
    author = "Lieberum, Tom  and
      Rajamanoharan, Senthooran  and
      Conmy, Arthur  and
      Smith, Lewis  and
